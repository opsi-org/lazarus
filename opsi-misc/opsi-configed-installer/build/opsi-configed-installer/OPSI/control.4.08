[Package]
version: 1demo
depends: 
incremental: False

[Product]
type: localboot
id: opsi-configed
name: opsi configed
description: opsi Graphical Management Interface (Windows / Linux)
advice: Caution: if a local opsi-configed is running all instances of javaw.exe are stopped
version: 4.0.8
priority: 0
licenseRequired: False
productClasses: 
setupScript: setup32.ins
uninstallScript: uninstall32.ins
updateScript: 
alwaysScript: 
onceScript: 
customScript: 
userLoginScript: 

[ProductDependency]
action: setup
requiredProduct: javavm
requiredStatus: installed
requirementType: before

[ProductProperty]
type: unicode
name: opsiadmin
multivalue: False
editable: True
description: user for opsi-configed

[ProductProperty]
type: unicode
name: client_language
multivalue: False
editable: False
description: client_language
values: ["auto", "da", "de", "en", "es", "fr", "pl", "tr"]
default: ["auto"]

[ProductProperty]
type: unicode
name: memory_requirement
multivalue: False
editable: True
description: MBs requested configed execution
values: ["1024", "1536", "2048", "512"]
default: ["1024"]

[ProductProperty]
type: bool
name: sqldata_force
description: Activate direct data transfer from database on start (only with active mysql backend)
default: False

[ProductProperty]
type: unicode
name: check_reachable_interval
multivalue: False
editable: True
description: Interval [min] for repeating the background reachable check for all clients ("0" = turned off)
values: ["0", "10", "15", "5"]
default: ["0"]

